# Git history — never needed in the image, and it's ~560MB of build context.
.git
**/.git

# flyctl launch added from .gitignore
# Agent / editor config
**/AGENTS.md
**/CLAUDE.md
**/.claude
**/.opencode
**/.codex
**/.agents
**/PLAN.md
**/opencode.json

# --- Python ---
**/__pycache__
**/*.pyc
**/*.py[cod]
**/.venv
**/venv
**/.mypy_cache
**/.ruff_cache
**/.pytest_cache
**/*.egg-info
**/dist
**/build

# --- ZK circuit artifacts (large, regenerated) ---
**/*.srs
# NOTE: model_store/*.joblib are intentionally NOT ignored here — the real
# trained model is baked into the image (COPY model_store in the Dockerfile).

# --- Rust / Soroban build artifacts ---
target
contracts/target
**/**/target

# Soroban test snapshots (regenerated on every `cargo test`)
**/test_snapshots

# --- Secrets / local config ---
**/.env
**/.env.local
**/*.env.local
**/*.key
**/*-service-account.json

# Local ingest seed data (not committed)
data
**/bq_population_180d.csv

# flyctl launch added from .pytest_cache/.gitignore
# Created by pytest automatically.
.pytest_cache/**/*

# flyctl launch added from .ruff_cache/.gitignore
# Automatically created by ruff.
.ruff_cache/**/*

# flyctl launch added from contracts/bindings/ts/attestor-registry/.gitignore
contracts/bindings/ts/attestor-registry/**/node_modules
contracts/bindings/ts/attestor-registry/**/out

# flyctl launch added from contracts/bindings/ts/mock-lending-pool/.gitignore
contracts/bindings/ts/mock-lending-pool/**/node_modules
contracts/bindings/ts/mock-lending-pool/**/out

# flyctl launch added from contracts/bindings/ts/risk-attestation/.gitignore
contracts/bindings/ts/risk-attestation/**/node_modules
contracts/bindings/ts/risk-attestation/**/out

# flyctl launch added from contracts/bindings/ts/wallet-identity/.gitignore
contracts/bindings/ts/wallet-identity/**/node_modules
contracts/bindings/ts/wallet-identity/**/out

# flyctl launch added from frontend/.gitignore
frontend/**/node_modules
frontend/**/.vite
frontend/**/dist
frontend/**/.vercel

# flyctl launch added from ml/zk/identity_circuit/.gitignore
# Toolchain + large build artifacts (regenerated by build.sh)
ml/zk/identity_circuit/**/node_modules
ml/zk/identity_circuit/**/*.ptau
ml/zk/identity_circuit/**/*.zkey
ml/zk/identity_circuit/**/*.r1cs
ml/zk/identity_circuit/**/*.sym
ml/zk/identity_circuit/**/*.wasm
ml/zk/identity_circuit/**/identity_js
ml/zk/identity_circuit/**/witness.wtns
# snarkjs JSON intermediates
ml/zk/identity_circuit/**/vkey.json
ml/zk/identity_circuit/**/proof.json
ml/zk/identity_circuit/**/public.json
ml/zk/identity_circuit/**/input.json
# Working copies of the blobs; the committed test vectors live in
# contracts/risk-attestation/src/dg6_vectors/ (copied there by build.sh).
ml/zk/identity_circuit/**/vk.bin
ml/zk/identity_circuit/**/proof.bin
fly.toml
