# ZKredit frontend environment template
# Copy to .env.local and fill in values from the root .env.local.

# Stellar network (testnet or mainnet)
VITE_STELLAR_NETWORK=testnet

# Public network RPC (no secrets)
VITE_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
VITE_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Contract IDs populated by infra/scripts/deploy-testnet.sh
VITE_CONTRACT_ID_RISK_ATTESTATION=
VITE_CONTRACT_ID_ATTESTOR_REGISTRY=
VITE_CONTRACT_ID_MOCK_LENDING_POOL=

# ZKredit API base URL
VITE_API_BASE_URL=http://localhost:8000
