{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/App.tsx",
    "src/components/Catchphrase.tsx",
    "src/components/Footer.tsx",
    "src/components/Hero.tsx",
    "src/components/HowItWorks.tsx",
    "src/components/HowVisuals.tsx",
    "src/components/Icons.tsx",
    "src/components/Nav.tsx",
    "src/components/PageGlow.tsx",
    "src/components/Placeholder.tsx",
    "src/components/TryAttestation.tsx",
    "src/components/UseCases.tsx",
    "src/components/WhatWeDo.tsx",
    "src/components/WhatsProven.tsx",
    "src/index.css",
    "src/lib/api.ts",
    "src/lib/freighter.ts",
    "src/lib/motion.ts",
    "src/lib/navigation.ts",
    "src/main.tsx",
    "src/pages/AttestationPage.tsx",
    "src/pages/LandingPage.tsx",
    "src/three/ParticleSphere.tsx",
    "src/vite-env.d.ts"
  ]
}
