# ZKredit environment template
# Copy to .env and fill in real values.
# This file must stay checked in with placeholders only (no secrets).

# Data stores
DATABASE_URL=postgresql://zkredit:zkredit@localhost:5432/zkredit
REDIS_URL=redis://localhost:6379

# Optional data ingestion
BIGQUERY_PROJECT=
DUNE_API_KEY=

# Stellar network: testnet or mainnet
STELLAR_NETWORK=testnet

# Admin and attestor keys for testnet deploys.
# The deploy script generates and funds these automatically; leave blank
# until after the first successful deploy, then copy from .env.local.
ADMIN_ADDRESS=
ADMIN_SEED=
ATTESTOR_ADDRESS=
ATTESTOR_SEED=

# Contract IDs populated by deploy-testnet.sh after Day 4.
CONTRACT_ID_RISK_ATTESTATION=
CONTRACT_ID_ATTESTOR_REGISTRY=
CONTRACT_ID_MOCK_LENDING_POOL=
CONTRACT_ID_WALLET_IDENTITY=
