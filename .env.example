# ZKredit environment template.
# Copy to .env and fill in real values. Keep placeholders only in git (no secrets).

# --- Data stores ---
DATABASE_URL=postgresql+asyncpg://zkredit:zkredit@localhost:5432/zkredit
REDIS_URL=redis://localhost:6379

# --- API / CORS / auth (1.3, 1.4) ---
# Comma-separated exact origins allowed to call the API (localhost dev + the
# deployed Vercel prod URL). CORS_ALLOW_ORIGIN_REGEX (optional) matches Vercel
# preview deployments, e.g. https://<project>-<hash>-<team>\.vercel\.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
CORS_ALLOW_ORIGIN_REGEX=
# HMAC key for signing the wallet session cookie. MUST be a strong random value
# in production (set via `fly secrets set SESSION_SECRET=...`); leave blank locally.
SESSION_SECRET=
SESSION_TTL_SECONDS=86400
# Abuse limits on the paid-proving /attest/* endpoints.
ATTEST_RATE_PER_ADDRESS_24H=3
ATTEST_RATE_PER_IP_HOUR=20

# --- Stellar / Horizon ---
# Mainnet is the demo target (real wallet history).
HORIZON_URL=https://horizon.stellar.org
# Stellar network: testnet or mainnet
STELLAR_NETWORK=testnet

# How far back to ingest operation history (used by the DG3 fail-action 1-year cap).
INGEST_MAX_OPERATIONS=2000

# --- BigQuery (DG3: crypto_stellar) ---
# Path to a GCP service-account JSON key. Leave blank if running Horizon-only (DG3 fail action).
GOOGLE_APPLICATION_CREDENTIALS=
BIGQUERY_PROJECT=
DUNE_API_KEY=

# --- Model/runtime ---
MODEL_DIR=model_store
ENABLE_ZK_PROOF=false

# --- Soroban contract submission ---
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Admin and attestor keys for deploys / API submissions.
# The deploy script generates and funds these automatically; leave blank
# until after the first successful deploy, then copy from .env.local.
ADMIN_ADDRESS=
ADMIN_SEED=
ATTESTOR_ADDRESS=
ATTESTOR_SEED=

# Contract IDs populated by deploy-testnet.sh after deploy.
CONTRACT_ID_RISK_ATTESTATION=
CONTRACT_ID_ATTESTOR_REGISTRY=
CONTRACT_ID_MOCK_LENDING_POOL=
CONTRACT_ID_WALLET_IDENTITY=

# Stored attestation lifetime for API-side submission metadata.
ATTESTATION_TTL_SECONDS=2592000
